<?xml version="1.0" encoding="utf-8"?>
<layout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools">

    <data />

    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/main"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        tools:context=".MainActivity">

        <androidx.fragment.app.FragmentContainerView
            android:id="@+id/fragment_container"
            android:layout_width="0dp"
            android:layout_height="0dp"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintBottom_toTopOf="@id/nav_bar"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent" />

        <View
            android:id="@+id/nav_bar_shadow"
            android:layout_width="0dp"
            android:layout_height="0.5dp"
            android:background="?attr/colorOutlineVariant"
            app:layout_constraintBottom_toTopOf="@id/nav_bar"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent" />

        <View
            android:id="@+id/nav_bar"
            android:layout_width="0dp"
            android:layout_height="0dp"
            android:background="@android:color/white"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent" />

        <LinearLayout
            android:id="@+id/nav_nutrition"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:gravity="center"
            android:orientation="vertical"
            android:duplicateParentState="true"
            android:clickable="true"
            android:focusable="true"
            android:foreground="?attr/selectableItemBackgroundBorderless"
            android:paddingTop="6dp"
            android:paddingBottom="8dp"
            app:layout_constraintBottom_toBottomOf="@id/nav_bar"
            app:layout_constraintEnd_toStartOf="@id/nav_record"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="@id/nav_bar">

            <ImageView
                android:id="@+id/nav_nutrition_icon"
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:src="@drawable/ic_nav_nutrition"
                android:importantForAccessibility="no" />

            <TextView
                android:id="@+id/nav_nutrition_label"
                style="@style/TextAppearance.Material3.LabelSmall"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:text="@string/nav_nutrition" />
        </LinearLayout>

        <LinearLayout
            android:id="@+id/nav_record"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:clickable="true"
            android:duplicateParentState="true"
            android:focusable="true"
            android:foreground="?attr/selectableItemBackgroundBorderless"
            android:gravity="center_horizontal"
            android:orientation="vertical"
            app:layout_constraintBottom_toBottomOf="@id/nav_bar"
            app:layout_constraintEnd_toStartOf="@id/nav_profile"
            app:layout_constraintStart_toEndOf="@id/nav_nutrition"
            app:layout_constraintTop_toTopOf="@id/nav_bar">

            <ImageView
                android:id="@+id/nav_record_icon"
                android:layout_width="52dp"
                android:layout_height="52dp"
                android:background="@drawable/bg_nav_center"
                android:elevation="4dp"
                android:importantForAccessibility="no"
                android:outlineProvider="background"
                android:scaleType="center"
                android:src="@drawable/ic_nav_record" />

            <TextView
                android:id="@+id/nav_record_label"
                style="@style/TextAppearance.Material3.LabelSmall"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="2dp"
                android:text="@string/nav_record" />
        </LinearLayout>

        <LinearLayout
            android:id="@+id/nav_profile"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:clickable="true"
            android:duplicateParentState="true"
            android:focusable="true"
            android:foreground="?attr/selectableItemBackgroundBorderless"
            android:gravity="center"
            android:orientation="vertical"
            android:paddingTop="6dp"
            android:paddingBottom="8dp"
            app:layout_constraintBottom_toBottomOf="@id/nav_bar"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toEndOf="@id/nav_record"
            app:layout_constraintTop_toTopOf="@id/nav_bar">

            <ImageView
                android:id="@+id/nav_profile_icon"
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:importantForAccessibility="no"
                android:src="@drawable/ic_nav_profile" />

            <TextView
                android:id="@+id/nav_profile_label"
                style="@style/TextAppearance.Material3.LabelSmall"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:text="@string/nav_profile" />
        </LinearLayout>

        <View
            android:id="@+id/nav_left_extra"
            android:layout_width="0dp"
            android:layout_height="0dp"
            android:visibility="gone"
            app:layout_constraintBottom_toBottomOf="@id/nav_bar"
            app:layout_constraintEnd_toStartOf="@id/nav_nutrition"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="@id/nav_bar"
            tools:visibility="gone" />

        <View
            android:id="@+id/nav_right_extra"
            android:layout_width="0dp"
            android:layout_height="0dp"
            android:visibility="gone"
            app:layout_constraintBottom_toBottomOf="@id/nav_bar"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toEndOf="@id/nav_profile"
            app:layout_constraintTop_toTopOf="@id/nav_bar"
            tools:visibility="gone" />

    </androidx.constraintlayout.widget.ConstraintLayout>
</layout>
