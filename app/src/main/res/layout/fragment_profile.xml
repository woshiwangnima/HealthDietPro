<?xml version="1.0" encoding="utf-8"?>
<layout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools">

    <FrameLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="?attr/colorSurface"
        tools:context=".ui.profile.ProfileFragment">

        <ScrollView
            android:layout_width="match_parent"
            android:layout_height="match_parent">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp">

                <!-- Settings gear -->
                <ImageView
                    android:id="@+id/settingsBtn"
                    android:layout_width="40dp"
                    android:layout_height="40dp"
                    android:layout_gravity="end"
                    android:clickable="true"
                    android:focusable="true"
                    android:background="?attr/selectableItemBackgroundBorderless"
                    android:padding="8dp"
                    android:src="@drawable/ic_settings"
                    android:tint="?attr/colorOnSurfaceVariant" />

                <!-- User info card -->
                <FrameLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:background="@drawable/card_user_info"
                    android:elevation="2dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:padding="16dp"
                        android:gravity="center_vertical">

                        <!-- Avatar + 切换用户图标 -->
                        <LinearLayout
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:orientation="vertical"
                            android:gravity="center_horizontal">

                            <TextView
                                android:id="@+id/avatarText"
                                android:layout_width="56dp"
                                android:layout_height="56dp"
                                android:gravity="center"
                                android:textSize="@dimen/text_size_subtitle"
                                android:textColor="@android:color/white"
                                android:textStyle="bold"
                                android:background="@drawable/avatar_circle"
                                tools:text="张" />

                            <ImageView
                                android:id="@+id/switchUserBtn"
                                android:layout_width="24dp"
                                android:layout_height="24dp"
                                android:layout_marginTop="4dp"
                                android:clickable="true"
                                android:focusable="true"
                                android:background="?attr/selectableItemBackgroundBorderless"
                                android:src="@drawable/ic_switch_user"
                                android:contentDescription="切换用户" />
                        </LinearLayout>

                        <!-- Name + info -->
                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:orientation="vertical"
                            android:layout_marginStart="14dp"
                            android:layout_marginEnd="10dp">

                            <TextView
                                android:id="@+id/profileName"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:textAppearance="@style/TextAppearance.Material3.TitleMedium"
                                android:textStyle="bold"
                                tools:text="张三" />

                            <!-- 第二行：性别图标 + 性别文字 | 年龄-岁 | 生日 -->
                            <LinearLayout
                                android:id="@+id/profileInfoLine2"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_marginTop="4dp"
                                android:gravity="center_vertical">

                                <TextView
                                    android:id="@+id/profileGenderIcon"
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:textSize="@dimen/text_size_body"
                                    tools:text="♂" />

                                <TextView
                                    android:id="@+id/profileGenderText"
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:layout_marginStart="2dp"
                                    android:textAppearance="@style/TextAppearance.Material3.BodySmall"
                                    android:textColor="?attr/colorOnSurfaceVariant"
                                    tools:text="男" />

                                <TextView
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:layout_marginStart="6dp"
                                    android:text=" | "
                                    android:textAppearance="@style/TextAppearance.Material3.BodySmall"
                                    android:textColor="?attr/colorOnSurfaceVariant" />

                                <TextView
                                    android:id="@+id/profileAge"
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:textAppearance="@style/TextAppearance.Material3.BodySmall"
                                    android:textColor="?attr/colorOnSurfaceVariant"
                                    tools:text="28岁" />

                                <TextView
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:layout_marginStart="6dp"
                                    android:text=" | "
                                    android:textAppearance="@style/TextAppearance.Material3.BodySmall"
                                    android:textColor="?attr/colorOnSurfaceVariant" />

                                <TextView
                                    android:id="@+id/profileBirthday"
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:textAppearance="@style/TextAppearance.Material3.BodySmall"
                                    android:textColor="?attr/colorOnSurfaceVariant"
                                    tools:text="1990-01-15" />
                            </LinearLayout>

                            <!-- 第三行：地区 | 病史（病史为"无"时不展示） -->
                            <LinearLayout
                                android:id="@+id/profileInfoLine3"
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:layout_marginTop="2dp"
                                android:gravity="center_vertical"
                                android:orientation="horizontal">

                                <TextView
                                    android:id="@+id/profileRegionLine"
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:textAppearance="@style/TextAppearance.Material3.BodySmall"
                                    android:textColor="?attr/colorOnSurfaceVariant"
                                    tools:text="北京" />

                                <TextView
                                    android:id="@+id/profileDiseaseSeparator"
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:layout_marginStart="6dp"
                                    android:text=" | "
                                    android:textAppearance="@style/TextAppearance.Material3.BodySmall"
                                    android:textColor="?attr/colorOnSurfaceVariant" />

                                <TextView
                                    android:id="@+id/profileDiseaseLine"
                                    android:layout_width="0dp"
                                    android:layout_height="wrap_content"
                                    android:layout_weight="1"
                                    android:textAppearance="@style/TextAppearance.Material3.BodySmall"
                                    android:textColor="?attr/colorOnSurfaceVariant"
                                    tools:text="高血压、2型糖尿病" />
                            </LinearLayout>
                        </LinearLayout>

                        <!-- 进入个人信息 -->
                        <com.google.android.material.button.MaterialButton
                            android:id="@+id/profileDetailBtn"
                            android:layout_width="40dp"
                            android:layout_height="40dp"
                            android:minWidth="0dp"
                            android:insetTop="0dp"
                            android:insetBottom="0dp"
                            android:contentDescription="个人信息"
                            style="@style/Widget.Material3.Button.TextButton"
                            app:icon="@drawable/ic_arrow_right"
                            app:iconTint="?attr/colorOnSurfaceVariant" />

                    </LinearLayout>

                </FrameLayout>

                <!-- Feature: User settings -->
                <com.google.android.material.button.MaterialButton
                    android:id="@+id/userSettingsBtn"
                    android:layout_width="match_parent"
                    android:layout_height="48dp"
                    android:layout_marginTop="24dp"
                    android:text="用户设置"
                    style="@style/Widget.Material3.Button.OutlinedButton" />

            </LinearLayout>
        </ScrollView>
    </FrameLayout>
</layout>
